{
  "name": "@specodec/typespec-emitter-fsharp",
  "version": "0.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typespec": {
    "emitter": true,
    "options": {
      "@specodec/typespec-emitter-fsharp": {
        "type": "object",
        "properties": {
          "emitter-output-dir": { "type": "string" },
          "ignore-reserved-keywords": { "type": "boolean" }
        },
        "required": ["emitter-output-dir"]
      }
    }
  },
  "scripts": { "build": "tsc", "prepare": "npm run build" },
  "dependencies": {},
  "devDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@specodec/typespec-emitter-core": "^1.0.2",
    "typescript": "^5.8.0"
  },
  "publishConfig": { "registry": "http://10.199.64.20:3000/api/packages/specodec/npm/" },
  "peerDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@specodec/typespec-emitter-core": "^1.0.0"
  }
}
